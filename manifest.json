{
  "manifest_version": 3,
  "name": "账号密码管理器",
  "version": "3.0.0",
  "description": "自动识别网页登录并保存密码，支持主密码加密保护、手动管理账号信息",
  "permissions": [
    "storage",
    "activeTab",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
    "action": {
        "default_popup": "index.html",
        "default_title": "账号密码管理器",
        "default_icon": "icon.png"
    }
}
